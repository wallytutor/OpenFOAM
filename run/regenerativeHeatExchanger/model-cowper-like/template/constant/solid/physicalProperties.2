FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant/solid";
    object      physicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heSolidThermo;
    mixture         pureMixture;
    specie          specie;
    energy          sensibleInternalEnergy;
    equationOfState rhoConst;
    thermo          eIcoTabulated;
    transport       tabulatedSolid;
}

mixture
{
    specie
    {
        molWeight       101.6;
    }

    equationOfState
    {
        rho             2800;
    }

    thermodynamics
    {
        hf              0;
        sf              0;
        Cv
        {
            values
            (
                (  200.0    1000.0 )
                ( 2000.0    1000.0 )
            );
        }
    }

    transport
    {
        kappa
        {
            values
            (
                (  200.0    2.0 )
                ( 2000.0    2.0 )
            );
        }
    }
}

