FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant/fluid";
    object      physicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Constant properties for debugging purposes: do not use in production!
//
// XXX: change Cp for heating/cooling accordingly, if needed.

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       sutherland;
    thermo          hConst;
    equationOfState perfectGas;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight       28.85097;
    }
    thermodynamics
    {
        // Cp              1004.4; // Cooling
        Cp              1100.0; // Heating
        hf              0;
    }
    transport
    {
        mu              3.0e-05;
        Pr              0.705;
    }
}

// ************************************************************************* //
