FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/fluid";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 1 -1 -2 0 0 0 0 ];

internalField   uniform 101325.0;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    fluidInlet
    {
        type            calculated;
        value           $internalField;
    }
    fluidOutlet
    {
        // type            fixedValue;
        type            calculated;
        value           $internalField;
    }
    fluid_to_solid
    {
        // type           zeroGradient;
        type            calculated;
        value           $internalField;
    }
    "cyclicFluid(Left|Right)"
    {
        type            cyclic;
    }
}

