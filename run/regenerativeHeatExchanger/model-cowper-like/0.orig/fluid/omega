FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/fluid";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 100;

boundaryField
{
    // XXX outlet is the inlet for hot gas and vice-versa!
    fluidOutlet
    {
        type            turbulentMixingLengthFrequencyInlet;
        mixingLength    0.00175;
        value           $internalField;
    }
    fluidInlet
    {
        type            inletOutlet;
        phi             phi;
        inletValue      $internalField;
        value           $internalField;
    }
    fluid_to_solid
    {
        type            omegaWallFunction;
        value           $internalField;
    }
    "cyclicFluid(Left|Right)"
    {
        type            cyclic;
    }
}


