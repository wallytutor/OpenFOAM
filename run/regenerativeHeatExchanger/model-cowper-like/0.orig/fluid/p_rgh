FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/fluid";
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 1 -1 -2 0 0 0 0 ];

// p - rho*g*h ~ 0
internalField   uniform 0.0;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    // XXX outlet is the inlet for hot gas and vice-versa!
    fluidOutlet
    {
        type            fixedFluxPressure;
        value           $internalField;
    }
    fluidInlet
    {
        // type            zeroGradient;
        type            fixedValue;
        value           $internalField;
    }
    fluid_to_solid
    {
        type            fixedFluxPressure;
        value           $internalField;
    }
    "cyclicFluid(Left|Right)"
    {
        type            cyclic;
    }
}

