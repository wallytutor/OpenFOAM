FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/solid";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 0 0 1 0 0 0 ];

#include "../../constant/userParameters"

internalField   uniform $fluidTemperature;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    "solid(Top|Bottom)"
    {
        type            externalTemperature;
        Ta              constant $envTemperature;
        h               uniform $envCoefficient;
        thicknessLayers ($wallThickness);
        kappaLayers     ($wallConductivity);
        value           $internalField;
    }
    solidSymmetry
    {
        type            zeroGradient;
    }
    solid_to_fluid
    {
        type            coupledTemperature;
        value           $internalField;
    }
    "cyclicSolid(Left|Right)"
    {
        type            cyclic;
    }
}


