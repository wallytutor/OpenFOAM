FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/fluid";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 0 0 1 0 0 0 ];

#include "../constant/userParameters"

internalField    uniform $solidTemperature;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    fluidHot
    {
        type            fixedValue;
        value           uniform $solidTemperature;
    }
    fluidCold
    {
        type            inletOutlet;
        value           uniform $solidTemperature;
        inletValue      uniform $solidTemperature;
    }
    fluid_to_solid
    {
        type            zeroGradient;
    }
    "cyclicFluid(Left|Right)"
    {
        type            cyclic;
    }
}


