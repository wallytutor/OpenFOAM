FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system/media";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    e
    {
        solver           GAMG;
        smoother         symGaussSeidel;
        tolerance        1.0e-06;
        relTol           1.0e-02;
        maxIter          100;
    }

    eFinal
    {
        $e;
        relTol           0;
    }
}

PIMPLE
{
    nNonOrthogonalCorrectors 0;
}

relaxationFactors
{
    equations
    {
        ".*" 1;
    }
}

