FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system/media";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    e
    {
        solver           PCG;
        preconditioner   DIC;
        tolerance        1.0e-06;
        relTol           0.01;
    }

    eFinal
    {
        $e;
        relTol           0;
    }
}

PIMPLE
{
    nNonOrthogonalCorrectors 0;

    residualControl
    {
        e                 1.0e-08;
    }
}

relaxationFactors
{
    equations
    {
        e                 0.8;
    }
}

